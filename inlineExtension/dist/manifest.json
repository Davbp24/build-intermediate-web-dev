{
  "manifest_version": 3,
  "name": "Inline",
  "description": "Annotate any webpage with sticky notes.",
  "version": "1.0",
  "permissions": ["storage", "activeTab", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_icon": "vite.svg"
  }
}
