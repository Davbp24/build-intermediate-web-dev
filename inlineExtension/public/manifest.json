{
  "manifest_version": 3,
  "name": "Inline",
  "description": "Annotate any webpage with sticky notes, highlights, and spatial saves.",
  "version": "1.1",
  "permissions": ["storage", "activeTab", "contextMenus", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "http://localhost:3001/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "vite.svg"
  }
}
